# Copy this file to .env and fill in your key.
GEMINI_API_KEY=your_key_here

# Optional: override the model (must be multimodal for photo reading).
# gemini-flash-latest is a current, self-updating multimodal alias.
GEMINI_MODEL=gemini-flash-latest

# --- Backend (FastAPI + MongoDB Atlas) ---
# Atlas connection string, e.g. mongodb+srv://user:pass@cluster.xxxx.mongodb.net/
MONGODB_URI=
DB_NAME=aarambhini
APP_ENV=dev

# --- Seller sessions ---
# HMAC key for signing session tokens. Leave blank in dev and an ephemeral one
# is generated per restart (sessions won't survive a reload). REQUIRED outside
# dev — the app refuses to issue tokens without it, because an unset secret
# would make tokens forgeable by anyone who reads this repo.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=
SESSION_TTL_HOURS=12

# Password given to the seeded demo sellers so the roster is loginable out of
# the box. Throwaway by design. The seeds only set it where a seller has no
# password yet, so re-seeding never overwrites a real one.
DEMO_SELLER_PASSWORD=aarambhini-demo

# --- Speech-to-Text ---
# Provider for seller voice notes. "sarvam" (India-first, best for regional +
# code-mixed speech) is primary; falls back to "gemini" native audio if Sarvam
# is unset or errors. Set STT_PROVIDER=gemini to use Gemini directly.
STT_PROVIDER=sarvam
SARVAM_API_KEY=your_sarvam_key_here
SARVAM_STT_MODEL=saarika:v2.5

# --- Her language (same Sarvam key) ---
# The listing publishes in English; these render the REVIEW in her language so
# she can understand what she's approving. Mayura translates, Bulbul speaks it
# aloud (she may speak her language fluently and still not read it).
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka

# --- Send to an external store (optional) ---
# After she approves a listing internally, she can push it to a real storefront
# as a live product. Leave blank to hide the "Send to your store" button. From
# a Shopify dev store: Settings -> Apps -> Develop apps -> create an app with
# the write_products scope, then reveal the Admin API access token.
SHOPIFY_SHOP_DOMAIN=          # e.g. your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=   # shpat_...
SHOPIFY_API_VERSION=2025-01
# Dev-store storefront password, shown to a self-serve demo viewer (dev stores
# stay password-gated). Throwaway + view-only. Leave blank outside a demo.
SHOPIFY_STOREFRONT_PASSWORD=
