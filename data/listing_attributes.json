{
  "_meta": {
    "note": "Meesho-style structured product attributes per category. Mirrors the fields real Meesho catalog forms require so a listing carries buyer-facing detail (gender, size, colour, fabric/material, pattern, etc.). 'required' fields must be present before a listing is complete; 'infer' hints where the value comes from: photo (Gemini vision), voice (seller's words), seller (must be confirmed by the seller), fixed (constant).",
    "version": 1
  },
  "common": [
    { "key": "color", "label": "Colour", "type": "text", "required": true, "infer": "photo" },
    { "key": "net_quantity", "label": "Net Quantity", "type": "text", "required": true, "infer": "voice", "default": "1" },
    { "key": "country_of_origin", "label": "Country of Origin", "type": "fixed", "required": true, "value": "India" }
  ],
  "categories": {
    "handloom_textiles": {
      "attributes": [
        { "key": "gender", "label": "Gender", "type": "enum", "options": ["Women", "Men", "Girls", "Boys", "Unisex"], "required": true, "infer": "voice" },
        { "key": "size", "label": "Size", "type": "enum", "options": ["Free Size", "S", "M", "L", "XL", "XXL"], "required": true, "infer": "seller" },
        { "key": "fabric", "label": "Fabric", "type": "enum", "options": ["Cotton", "Silk", "Jute", "Linen", "Khadi", "Georgette", "Chiffon", "Wool", "Blended"], "required": true, "infer": "voice" },
        { "key": "pattern", "label": "Pattern", "type": "enum", "options": ["Solid", "Printed", "Woven Design", "Embroidered", "Striped", "Checked", "Zari"], "required": false, "infer": "photo" },
        { "key": "occasion", "label": "Occasion", "type": "enum", "options": ["Daily", "Party", "Festive", "Wedding", "Formal"], "required": false, "infer": "voice" }
      ]
    },
    "apparel_readymade": {
      "attributes": [
        { "key": "gender", "label": "Gender", "type": "enum", "options": ["Women", "Men", "Girls", "Boys", "Unisex"], "required": true, "infer": "voice" },
        { "key": "size", "label": "Size", "type": "multi", "options": ["Free Size", "XS", "S", "M", "L", "XL", "XXL", "XXXL"], "required": true, "infer": "seller" },
        { "key": "fabric", "label": "Fabric", "type": "enum", "options": ["Cotton", "Rayon", "Silk", "Georgette", "Crepe", "Polyester", "Wool", "Denim", "Blended"], "required": true, "infer": "voice" },
        { "key": "sleeve_length", "label": "Sleeve Length", "type": "enum", "options": ["Sleeveless", "Short Sleeves", "Three-Quarter Sleeves", "Long Sleeves"], "required": false, "infer": "photo" },
        { "key": "pattern", "label": "Pattern", "type": "enum", "options": ["Solid", "Printed", "Embroidered", "Striped", "Checked", "Self Design"], "required": false, "infer": "photo" },
        { "key": "type", "label": "Type", "type": "text", "required": false, "infer": "voice" },
        { "key": "occasion", "label": "Occasion", "type": "enum", "options": ["Casual", "Party", "Festive", "Ethnic", "Formal"], "required": false, "infer": "voice" }
      ]
    },
    "food_packaged": {
      "attributes": [
        { "key": "net_weight", "label": "Net Weight", "type": "text", "required": true, "infer": "voice" },
        { "key": "veg_nonveg", "label": "Veg / Non-Veg", "type": "enum", "options": ["Vegetarian", "Non-Vegetarian", "Vegan"], "required": true, "infer": "voice" },
        { "key": "food_type", "label": "Type", "type": "text", "required": true, "infer": "voice" },
        { "key": "flavour", "label": "Flavour", "type": "text", "required": false, "infer": "voice" },
        { "key": "shelf_life", "label": "Shelf Life", "type": "text", "required": true, "infer": "seller" },
        { "key": "organic", "label": "Organic", "type": "enum", "options": ["Yes", "No"], "required": false, "infer": "voice" },
        { "key": "container_type", "label": "Container Type", "type": "enum", "options": ["Pouch", "Jar", "Box", "Bottle"], "required": false, "infer": "photo" }
      ]
    },
    "jewellery_precious": {
      "attributes": [
        { "key": "gender", "label": "Gender", "type": "enum", "options": ["Women", "Men", "Unisex"], "required": true, "infer": "voice" },
        { "key": "base_metal", "label": "Base Metal", "type": "enum", "options": ["Gold", "Silver"], "required": true, "infer": "voice" },
        { "key": "purity", "label": "Purity", "type": "enum", "options": ["14K", "18K", "20K", "22K", "23K", "24K", "925 Sterling Silver"], "required": true, "infer": "seller" },
        { "key": "gross_weight", "label": "Gross Weight (g)", "type": "number", "required": true, "infer": "seller" },
        { "key": "type", "label": "Type", "type": "enum", "options": ["Necklace", "Ring", "Earrings", "Bangle", "Chain", "Anklet", "Pendant"], "required": true, "infer": "photo" },
        { "key": "certification", "label": "Certification", "type": "enum", "options": ["BIS Hallmark", "Not Certified"], "required": true, "infer": "seller" }
      ]
    },
    "imitation_jewellery": {
      "attributes": [
        { "key": "gender", "label": "Gender", "type": "enum", "options": ["Women", "Girls", "Men", "Unisex"], "required": true, "infer": "voice" },
        { "key": "base_metal", "label": "Base Metal", "type": "enum", "options": ["Brass", "Alloy", "Copper", "Oxidised Metal", "Beads", "Mixed"], "required": true, "infer": "voice" },
        { "key": "plating", "label": "Plating", "type": "enum", "options": ["Gold Plated", "Silver Plated", "Oxidised", "Rose Gold", "No Plating"], "required": false, "infer": "photo" },
        { "key": "stone_type", "label": "Stone Type", "type": "enum", "options": ["Kundan", "American Diamond", "Pearl", "Meenakari", "No Stone"], "required": false, "infer": "photo" },
        { "key": "type", "label": "Type", "type": "enum", "options": ["Necklace", "Earrings", "Bangles", "Ring", "Anklet", "Maang Tikka", "Set"], "required": true, "infer": "photo" },
        { "key": "sizing", "label": "Sizing", "type": "enum", "options": ["Adjustable", "Free Size", "Fixed"], "required": false, "infer": "seller" }
      ]
    },
    "cosmetics_handmade": {
      "attributes": [
        { "key": "net_weight", "label": "Net Weight / Volume", "type": "text", "required": true, "infer": "voice" },
        { "key": "form", "label": "Form", "type": "enum", "options": ["Bar", "Liquid", "Cream", "Gel", "Powder", "Oil"], "required": true, "infer": "photo" },
        { "key": "skin_type", "label": "Suitable For", "type": "enum", "options": ["All Skin Types", "Oily", "Dry", "Sensitive", "Combination"], "required": false, "infer": "voice" },
        { "key": "key_ingredients", "label": "Key Ingredients", "type": "text", "required": true, "infer": "voice" },
        { "key": "fragrance", "label": "Fragrance", "type": "text", "required": false, "infer": "voice" },
        { "key": "shelf_life", "label": "Shelf Life", "type": "text", "required": true, "infer": "seller" }
