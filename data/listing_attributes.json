    "handicrafts_decor": {
      "attributes": [
        { "key": "material", "label": "Material", "type": "enum", "options": ["Terracotta", "Bamboo", "Wood", "Metal", "Ceramic", "Jute", "Clay", "Stone", "Cane"], "required": true, "infer": "voice" },
        { "key": "product_type", "label": "Type", "type": "text", "required": true, "infer": "voice" },
        { "key": "dimensions", "label": "Dimensions (L x B x H)", "type": "text", "required": true, "infer": "seller" },
        { "key": "finish", "label": "Finish", "type": "enum", "options": ["Handpainted", "Natural", "Polished", "Matte", "Glazed"], "required": false, "infer": "photo" }
      ]
    },
    "home_furnishing": {
      "attributes": [
        { "key": "material", "label": "Material", "type": "enum", "options": ["Cotton", "Polyester", "Jute", "Silk", "Velvet", "Microfiber", "Blended"], "required": true, "infer": "voice" },
        { "key": "size", "label": "Size", "type": "enum", "options": ["Single", "Double", "Queen", "King", "Standard", "Free Size"], "required": true, "infer": "seller" },
        { "key": "dimensions", "label": "Dimensions", "type": "text", "required": true, "infer": "seller" },
        { "key": "product_type", "label": "Type", "type": "text", "required": true, "infer": "voice" },
        { "key": "pattern", "label": "Pattern", "type": "enum", "options": ["Solid", "Printed", "Woven", "Embroidered", "Patchwork"], "required": false, "infer": "photo" },
        { "key": "pieces", "label": "Number of Items", "type": "number", "required": false, "infer": "voice" }
      ]
    },
    "toys_games": {
      "attributes": [
        { "key": "material", "label": "Material", "type": "enum", "options": ["Wood", "Cotton", "Plush", "Plastic", "Cloth"], "required": true, "infer": "voice" },
        { "key": "age_group", "label": "Age Group", "type": "enum", "options": ["0-1.5 Years", "1.5-3 Years", "3-5 Years", "5-8 Years", "8+ Years"], "required": true, "infer": "seller" },
        { "key": "product_type", "label": "Type", "type": "text", "required": true, "infer": "voice" },
        { "key": "dimensions", "label": "Dimensions", "type": "text", "required": false, "infer": "seller" }
      ]
    },
    "bags_leather": {
      "attributes": [
        { "key": "gender", "label": "Gender", "type": "enum", "options": ["Women", "Men", "Unisex"], "required": true, "infer": "voice" },
        { "key": "material", "label": "Material", "type": "enum", "options": ["Genuine Leather", "Faux Leather", "Jute", "Canvas", "Cotton", "Juco"], "required": true, "infer": "voice" },
        { "key": "type", "label": "Type", "type": "enum", "options": ["Handheld", "Sling", "Backpack", "Clutch", "Tote", "Wallet", "Pouch"], "required": true, "infer": "photo" },
        { "key": "compartments", "label": "No. of Compartments", "type": "number", "required": false, "infer": "seller" },
        { "key": "dimensions", "label": "Dimensions", "type": "text", "required": false, "infer": "seller" }
      ]
    },
    "ayurvedic_herbal": {
      "attributes": [
        { "key": "net_weight", "label": "Net Weight / Volume", "type": "text", "required": true, "infer": "voice" },
        { "key": "form", "label": "Form", "type": "enum", "options": ["Oil", "Powder", "Paste", "Tablet", "Liquid"], "required": true, "infer": "photo" },
        { "key": "key_ingredients", "label": "Key Ingredients", "type": "text", "required": true, "infer": "voice" },
        { "key": "concern", "label": "Concern", "type": "enum", "options": ["Hair Care", "Skin Care", "Immunity", "Digestion", "General Wellness"], "required": false, "infer": "voice" },
        { "key": "shelf_life", "label": "Shelf Life", "type": "text", "required": true, "infer": "seller" }
      ]
    },
    "candles_fragrance": {
      "attributes": [
        { "key": "type", "label": "Type", "type": "enum", "options": ["Pillar", "Jar", "Tealight", "Votive", "Incense", "Diffuser"], "required": true, "infer": "photo" },
        { "key": "wax_type", "label": "Wax / Material", "type": "enum", "options": ["Soy Wax", "Beeswax", "Paraffin", "Gel", "Not Applicable"], "required": true, "infer": "voice" },
        { "key": "fragrance", "label": "Fragrance", "type": "text", "required": true, "infer": "voice" },
        { "key": "net_weight", "label": "Net Weight", "type": "text", "required": true, "infer": "voice" },
        { "key": "burn_time", "label": "Burn Time", "type": "text", "required": false, "infer": "seller" }
      ]
    },
    "stationery_paper": {
      "attributes": [
        { "key": "material", "label": "Material", "type": "enum", "options": ["Handmade Paper", "Recycled Paper", "Card Stock", "Kraft Paper", "Mixed"], "required": true, "infer": "voice" },
        { "key": "product_type", "label": "Type", "type": "text", "required": true, "infer": "voice" },
        { "key": "dimensions", "label": "Size", "type": "text", "required": true, "infer": "seller" },
        { "key": "pages", "label": "No. of Pages / Sheets", "type": "number", "required": false, "infer": "voice" },
        { "key": "ruling", "label": "Ruling", "type": "enum", "options": ["Ruled", "Unruled", "Dotted", "Not Applicable"], "required": false, "infer": "voice" }
      ]
    }
  }
}
